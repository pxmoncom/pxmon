# PXMON environment variables
# Copy to .env and fill in real values. Never commit .env.

# Solana RPC
PXMON_RPC_URL=https://api.devnet.solana.com
PXMON_NETWORK=devnet
PXMON_KEYPAIR_PATH=~/.config/solana/id.json

# API server
PXMON_API_PORT=3000
PXMON_API_HOST=0.0.0.0
PXMON_LOG_LEVEL=info

# Agent runtime
PXMON_AGENT_TICK_MS=15000
PXMON_AGENT_OFFLINE_CAP_HOURS=4

# Optional LLM providers (agents use one if set)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Database (if used by the API server)
DATABASE_URL=postgres://user:pass@localhost:5432/pxmon
