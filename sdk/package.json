{
  "name": "@pxmon/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for PXMON - AI agent monster RPG on Solana. Build agents, read on-chain state, and submit transactions.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.js",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest --config jest.config.js",
    "lint": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "pxmon",
    "solana",
    "anchor",
    "sdk",
    "ai-agent",
    "monster-rpg",
    "web3",
    "rpg",
    "on-chain"
  ],
  "author": {
    "name": "pxmon core",
    "url": "https://pxmon.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pxmoncom/pxmon.git",
    "directory": "sdk"
  },
  "homepage": "https://pxmon.com",
  "bugs": {
    "url": "https://github.com/pxmoncom/pxmon/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "sideEffects": false,
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/web3.js": "^1.95.0",
    "borsh": "^2.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.2"
  }
}
